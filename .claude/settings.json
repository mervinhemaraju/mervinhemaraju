{
  "permissions": {
    "allow": [
      "Bash(az account show*)",
      "Bash(git remote get-url*)",
      "Bash(echo*)",
      "Bash(printenv*)",
      "Bash(AZURE_DEVOPS_EXT_PAT=*)",
      "Bash(python3 -c*)",
      "Bash(curl -s*)",
      "Bash(git checkout -b*)",
      "Bash(kubectl get *)",
      "Bash(kubectl logs *)",
      "Bash(az boards work-item*)",
      "Bash(az repos pr*)",
      "Bash(git diff*)",
      "Bash(git branch --show-current*)",
      "Bash(find .azuredevops*)",
      "Write(/tmp/azdo_*)"
    ],
    "deny": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git add*)",
      "Bash(git reset --hard*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(terraform force-unlock*)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "effortLevel": "high",
  "tui": "default",
  "theme": "dark-ansi",
  "autoApprove": false
}
