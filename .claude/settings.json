{
  "permissions": {
    "allow": [
      "Bash(az account show*)",
      "Bash(git remote get-url*)",
      "Bash(echo*)",
      "Bash(printenv*)",
      "Bash(AZURE_DEVOPS_EXT_PAT=*)",
      "Bash(python3 -c*)",
      "Bash(curl -s*)",
      "Bash(git checkout -b*)"
    ],
    "deny": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git add*)",
      "Bash(git reset --hard*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(terraform force-unlock*)"
    ]
  },
  "effortLevel": "high",
  "theme": "dark-ansi",
  "autoApprove": false,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
